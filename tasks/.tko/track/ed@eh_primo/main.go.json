            "content": "package main\n\nimport (\n\t\"fmt\"\n)\n\n// x: n\u00famero que est\u00e1 sendo testado\n// div: divisor que est\u00e1 sendo testado\nfunc eh_primo(x int, div int) bool {\n\tif x == 1 {\n\t\treturn false\n\t}\n\tif div < x {\n\t\tif x%div != 0 {\n\t\t\treturn eh_primo(x, div+1)\n\t\t}\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc main() {\n\tvar x int\n\tfmt.Scan(&x)\n\tif eh_primo(x, 2) {\n\t\tfmt.Println(\"true\")\n\t} else {\n\t\tfmt.Println(\"false\")\n\t}\n}\n",
